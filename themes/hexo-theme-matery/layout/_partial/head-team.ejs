<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<link rel="icon" type="image/svg+xml" href="/team/images/favicon.ico">

  <meta name="description" content="<%= page.title || '智启未来 - 专业的创业培训与赋能平台' %>">
  <meta name="keywords" content="创业培训, 创新创业, 企业家研修, 智启未来">
	
	<title><%= page.title %></title>
	
	<!-- 引入 Tailwind CSS -->
	<script src="https://cdn.tailwindcss.com"></script>
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
	<link rel="stylesheet" href="/css/team/custom-team.css">
	<style>
			@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap');
			body { font-family: 'Noto Sans SC', sans-serif; }
			.nav-link { position: relative; }
			.nav-link::after {
					content: ''; position: absolute; width: 0; height: 2px; bottom: -4px; left: 0;
					background-color: #4f46e5; transition: width 0.3s;
			}
			/* 使用 EJS 逻辑判断当前页面，自动添加 active 类 */
			.nav-link<% if (page.path === 'team/index.html') { %>.active<% } %>::after,
			.nav-link:hover::after { width: 100%; }
			
			/* 针对其他页面的判断逻辑示例 */
			<% if (page.path === 'team/products/index.html') { %>
					.nav-products::after { width: 100%; }
					.nav-products { color: #4f46e5; font-weight: 600; }
			<% } %>
	</style>
</head>